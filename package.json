{
  "name": "@1digital/pricing",
  "version": "0.2.0",
  "description": "Single source of truth for Workspace CMS pricing, allowances, overage, SLA, fair-use, and billing lifecycle. Consumed by 1digital-sites (workspacecms.ai), v0-1-digital-ai-dashboard (app.1digital.ai), and 1digital-new-site (1digitalagency.com/cms-platform).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "import": "./dist/pricing.js",
      "default": "./dist/pricing.js"
    },
    "./derived": {
      "types": "./dist/derived.d.ts",
      "import": "./dist/derived.js",
      "default": "./dist/derived.js"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/*.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsx": "^4.22.3",
    "@types/node": "^20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/1Digital-Dev/pricing.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "UNLICENSED",
  "private": true
}
